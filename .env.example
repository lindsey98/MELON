# MELON / AgentDojo environment variables.
#
# Usage:
#   1. Copy this file to `.env`:   cp .env.example .env
#   2. Fill in the values you need (delete or leave blank the ones you don't).
#   3. Load it into your shell before running:
#          set -a && source .env && set +a
#
# Notes:
#   - AgentDojo's benchmark script also auto-loads `.env` from the current
#     directory (via python-dotenv), but `set -a && source .env && set +a`
#     additionally exports the variables to other tools (e.g. `vllm serve`,
#     `huggingface-cli`).
#   - Only set the variables relevant to the providers you actually use.
#   - `.env` is git-ignored; never commit your real keys.

# ============================================================================
# Agent-LLM provider credentials (used by AgentDojo to drive the agent)
# ============================================================================

# OpenAI hosted models (e.g. --model gpt-4o-2024-05-13)
OPENAI_API_KEY=

# Anthropic hosted models (e.g. --model claude-3-5-sonnet-20241022)
ANTHROPIC_API_KEY=

# Together AI – hosted open models (e.g. Mixtral, Llama-3 via Together)
TOGETHER_API_KEY=

# Cohere models (Command R / R+). The Cohere SDK reads CO_API_KEY.
CO_API_KEY=

# Google Gemini is served through Vertex AI (NOT a plain GOOGLE_API_KEY).
# Set up Application Default Credentials (`gcloud auth application-default login`)
# and provide your GCP project / location:
GCP_PROJECT=
GCP_LOCATION=

# ============================================================================
# Locally-served agent LLMs (Qwen3-30B-A3B-Instruct-2507, Llama-3.3-70B-Instruct)
# ============================================================================

# Port of your local vLLM server, used by `--model local` and `--model vllm_parsed`.
LOCAL_LLM_PORT=8000

# Any OpenAI-compatible server, used by `--model openai-compatible`
# (pair with `--model-id <served-model-name>`). Use "EMPTY" as the key for vLLM.
OPENAI_COMPATIBLE_BASE_URL=http://localhost:8000/v1
OPENAI_COMPATIBLE_API_KEY=EMPTY

# ============================================================================
# MELON detection-embedding backend (used by class MELON)
# ============================================================================

# Backend: "openai" | "openai-compatible" (aliases: local / vllm) | "sentence-transformers"
MELON_EMBED_PROVIDER=openai

# Embedding model name.
#   - openai backend default:               text-embedding-3-large
#   - sentence-transformers backend default: BAAI/bge-large-en-v1.5
MELON_EMBED_MODEL=text-embedding-3-large

# Optional override of the OpenAI endpoint for the "openai" embedding backend.
# (OPENAI_API_KEY above is reused for authentication.)
OPENAI_BASE_URL=

# Local OpenAI-compatible embedding server, used when MELON_EMBED_PROVIDER is
# "openai-compatible" (e.g. a separate vLLM/TEI instance on port 8001).
MELON_EMBED_BASE_URL=http://localhost:8001/v1
MELON_EMBED_API_KEY=EMPTY
